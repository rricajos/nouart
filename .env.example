# Nou Art — variables de entorno.
# En local: copia a `.env`. En el VPS: pon los valores reales antes de `docker stack deploy`.

# Contraseña del panel /admin (¡cámbiala!).
ADMIN_PASSWORD=cambia-esta-contrasena

# Clave para firmar la sesión del admin. Genera una larga y aleatoria:
#   openssl rand -hex 32
SESSION_SECRET=genera-una-clave-larga-aleatoria

# Envío de emails de contacto (opcional; sin ella los mensajes se guardan en data/outbox.jsonl).
# Alta en https://resend.com — dominio nouart.org verificado.
RESEND_API_KEY=
MAIL_FROM=Nou Art <noreply@nouart.org>

# Email que recibe los mensajes de contacto cuando el artista no tiene email propio.
CONTACT_FALLBACK=hola@nouart.org

# Dónde persisten la BD SQLite y las imágenes subidas (en el contenedor: /data via volumen).
DATA_DIR=./data
